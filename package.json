{
  "name": "gamemaster-webserver",
  "version": "1.0.0",
  "description": "customized webserver for tabletop campaigns",
  "main": "app.ts",
  "scripts": {
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "tsc -p tsconfig.client.json",
    "build": "npm run build:server && npm run build:client",
    "start": "npm run build && node dist/server/app.js",
    "clean": "tsc --build --clean tsconfig.server.json tsconfig.client.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sksalter503/Gamemaster-Webserver.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/sksalter503/Gamemaster-Webserver/issues"
  },
  "homepage": "https://github.com/sksalter503/Gamemaster-Webserver#readme",
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/typescript": "^0.4.29",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "express": "^5.2.1",
    "path": "^0.12.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
