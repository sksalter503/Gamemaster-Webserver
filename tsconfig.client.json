{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "rootDir": "src",
        "outDir": "public/scripts",
        "allowSyntheticDefaultImports": true,
        "strict": false,
        "skipLibCheck": true
    },
    "include": [
        "src/client",
        "src/shared"
    ]
}